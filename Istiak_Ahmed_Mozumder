            ham.classList.remove('open');
            mob.classList.remove('open');
            body.style.overflow = '';
        }

        ham.addEventListener('click', (e) => {
            e.stopPropagation();
            if (mob.classList.contains('open')) {
                closeMenu();
            } else {
                openMenu();
            }
        });

