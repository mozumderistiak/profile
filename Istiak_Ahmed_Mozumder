            arts.slice(shown, shown + n).forEach(a => {
                const el = document.createElement('div');
                el.className = 'article-item reveal';
                el.innerHTML = `<div><p class="article-date">${a.date}</p><h3 class="article-title">${a.title}</h3><p class="article-subtitle">${a.sub}</p></div><img class="article-img" src="${a.img}" alt="${a.title}" loading="lazy"/>`;
                list.appendChild(el);
                obs.observe(el);
            });
            shown = Math.min(shown + n, arts.length);
            const btn = document.getElementById('loadMoreBtn');
            if (shown >= arts.length) { btn.disabled = true; btn.textContent = 'All Articles Loaded'; }
        }
        loadArts(4);
        document.getElementById('loadMoreBtn').addEventListener('click', () => loadArts(3));
        document.addEventListener("DOMContentLoaded", function () {
            let expShown = 4;
            const expCards = document.querySelectorAll('#expGrid .exp-card');
            const expBtn = document.getElementById('loadMoreExpBtn');
            const expWrap = document.getElementById('loadMoreExpWrap');
            function loadMoreExp() {
                let nextCards = Array.from(expCards).slice(expShown, expShown + 3);
                nextCards.forEach(card => {
                    card.classList.remove('exp-hidden');
                    if (typeof obs !== "undefined") {
                        obs.observe(card);
                    }
                });
                expShown = Math.min(expShown + 3, expCards.length);
                if (expShown >= expCards.length) {
                    expBtn.disabled = true;
                    expBtn.textContent = 'All Loaded';
                }
            }
            if (expBtn) {
                expBtn.addEventListener('click', loadMoreExp);
                function initExpMobile() {
                    if (window.innerWidth <= 768) {
                        expWrap.style.display = 'block';
                        expCards.forEach((card, i) => {
                            if (i >= 4) {
                                card.classList.add('exp-hidden');
                            } else {
                                card.classList.remove('exp-hidden');
                            }
                        });
                        expShown = 4;
                        expBtn.disabled = false;
                        expBtn.textContent = 'Load More';
                    } else {
                        expCards.forEach(c => c.classList.remove('exp-hidden'));
                        expShown = expCards.length;
                        expWrap.style.display = 'none';
                    }
                }
                initExpMobile();
                window.addEventListener('resize', initExpMobile);
            }
        });

        document.getElementById('formSubmit').addEventListener('click', function () {
            this.textContent = 'Sending…'; this.disabled = true;
            setTimeout(() => { this.textContent = 'Message Sent ✓'; this.style.background = 'var(--sage)'; }, 1200);
        });

        const secs = [...document.querySelectorAll('section[id]')];
        const nls = [...document.querySelectorAll('.nav-links a')];
        window.addEventListener('scroll', () => {
            let cur = '';
            secs.forEach(s => { if (window.scrollY >= s.offsetTop - 130) cur = s.id; });
            nls.forEach(a => { a.style.color = ''; if (a.getAttribute('href') === '#' + cur) a.style.color = 'var(--dune)'; });
        }, { passive: true });

        (function () {
            const expCards = document.querySelectorAll('#expGrid .exp-card');
            const expWrap = document.getElementById('loadMoreExpWrap');
            const expBtn = document.getElementById('loadMoreExpBtn');
            if (!expBtn || !expWrap) return;
            let expShown = 3;
            function updateExpVisibility() {
                const isMobile = window.innerWidth <= 768;
                if (isMobile) {
                    expShown = 3;
                    expCards.forEach((card, index) => {
                        if (index >= 3) {
                            card.classList.add('exp-hidden');
                        } else {
                            card.classList.remove('exp-hidden');
                        }
                    });

                    if (expCards.length > 3) {
                        expWrap.style.display = 'block';
                        expBtn.disabled = false;
                        expBtn.textContent = 'Load More Experience';
                    } else {
                        expWrap.style.display = 'none';
                    }
                } else {
                    expCards.forEach(card => {
                        card.classList.remove('exp-hidden');
                    });
                    expWrap.style.display = 'none';
                    expShown = expCards.length;
                }
            }

            function loadMoreExperience() {
                const isMobile = window.innerWidth <= 768;
                if (!isMobile) return;

                // Show next 3 cards
                let nextVisible = Math.min(expShown + 3, expCards.length);

                for (let i = expShown; i < nextVisible; i++) {
                    if (expCards[i]) {
                        expCards[i].classList.remove('exp-hidden');
                    }
                }

                expShown = nextVisible;
                if (expShown >= expCards.length) {
                    expBtn.disabled = true;
                    expBtn.textContent = 'All Loaded';
                }
            }

            if (!document.querySelector('#expHiddenStyle')) {
                const style = document.createElement('style');
                style.id = 'expHiddenStyle';
                style.textContent = '.exp-hidden { display: none !important; }';
                document.head.appendChild(style);
            }

            updateExpVisibility();

            let resizeTimer;
            window.addEventListener('resize', function () {
                clearTimeout(resizeTimer);
                resizeTimer = setTimeout(updateExpVisibility, 200);
            });

            expBtn.addEventListener('click', loadMoreExperience);
        })();

        (function () {
            function initCertifications() {
                const portraitRow = document.getElementById('certPortraitRow');
                const landscapeRow = document.getElementById('certLandscapeRow');
                if (!portraitRow || !landscapeRow) return;

                const portraitCards = Array.from(portraitRow.querySelectorAll('.cert-card'));
                const landscapeCards = Array.from(landscapeRow.querySelectorAll('.cert-card'));
                const allCertCards = [...portraitCards, ...landscapeCards];

                const certWrap = document.getElementById('loadMoreCertWrap');
                const certBtn = document.getElementById('loadMoreCertBtn');
                if (!allCertCards.length || !certBtn || !certWrap) return;

                const INITIAL_SHOW = 6;
                let currentVisible = 0;

                function showCards(upTo) {
                    allCertCards.forEach((card, index) => {
                        if (index < upTo) {
                            card.classList.remove('cert-hidden');
                        } else {
                            card.classList.add('cert-hidden');
                        }
                    });
                }

                function updateCertVisibility() {
                    const isMobile = window.innerWidth <= 768;

                    if (isMobile) {
                        currentVisible = INITIAL_SHOW;
                        showCards(currentVisible);

                        if (allCertCards.length > INITIAL_SHOW) {
                            certWrap.style.display = 'block';
                            certBtn.disabled = false;
                            certBtn.textContent = 'Load More Certifications';
                        } else {
                            certWrap.style.display = 'none';
                        }
                    } else {
                        allCertCards.forEach(card => card.classList.remove('cert-hidden'));
                        certWrap.style.display = 'none';
                        currentVisible = allCertCards.length;
                    }
                }

                certBtn.addEventListener('click', function () {
                    const isMobile = window.innerWidth <= 768;
                    if (!isMobile) return;

                    const nextVisible = Math.min(currentVisible + 6, allCertCards.length);
                    showCards(nextVisible);
                    currentVisible = nextVisible;

                    if (currentVisible >= allCertCards.length) {
                        certBtn.disabled = true;
                        certBtn.textContent = 'All Loaded';
                    }
                });

                updateCertVisibility();

                let resizeTimer;
                window.addEventListener('resize', function () {
                    clearTimeout(resizeTimer);
                    resizeTimer = setTimeout(updateCertVisibility, 150);
                });
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initCertifications);
            } else {
                initCertifications();
            }
        })();
    </script>


    <script>
        const CONTACT_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbzTrVBzpLK4Xu2UXdo6bZE5Ov9ffRt0E8h0ANzRjBI1kwMzuJE3sZbq6T63hD7KoEiE/exec";
        const contactBtn = document.getElementById('contactSubmitBtn');
        const contactStatus = document.getElementById('contactStatus');
        function openModal() {
            const modal = document.getElementById('successModal');
            if (modal) {
                modal.style.display = 'flex';
                document.body.style.overflow = 'hidden';
            }
        }
        window.closeModal = function () {
            const modal = document.getElementById('successModal');
            if (modal) {
                modal.style.display = 'none';
                document.body.style.overflow = '';
            }
        }
        document.addEventListener('click', function (e) {
            const modal = document.getElementById('successModal');
            if (modal && modal.style.display === 'flex' && e.target === modal) {
                closeModal();
            }
        });
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                const modal = document.getElementById('successModal');
                if (modal && modal.style.display === 'flex') {
                    closeModal();
                }
            }
        });

        async function submitContactForm() {
            if (!contactBtn) return;
            const name = document.getElementById('contactName')?.value.trim() || '';
            const email = document.getElementById('contactEmail')?.value.trim() || '';
            const country = document.getElementById('contactCountry')?.value.trim() || '';
            const subject = document.getElementById('contactSubject')?.value.trim() || '';
            const message = document.getElementById('contactMessage')?.value.trim() || '';
            if (!name || !email || !country || !subject || !message) {
                if (contactStatus) {
                    contactStatus.innerHTML = '❌ Please fill in all fields';
                    contactStatus.style.color = '#b55b35';
                }
                return;
            }

            if (!email.includes('@') || !email.includes('.')) {
                if (contactStatus) {
                    contactStatus.innerHTML = '❌ Please enter a valid email address';
                    contactStatus.style.color = '#b55b35';
                }
                return;
            }

            contactBtn.disabled = true;
            contactBtn.textContent = 'Sending...';

            if (contactStatus) {
                contactStatus.innerHTML = '📨 Sending message...';
                contactStatus.style.color = '#7a4f35';
            }

            const formData = new URLSearchParams();
            formData.append('name', name);
            formData.append('email', email);
            formData.append('country', country);
            formData.append('subject', subject);
            formData.append('message', message);

            try {
                const response = await fetch(CONTACT_SCRIPT_URL, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: formData
                });

                const result = await response.text();
                console.log("Server response:", result);
                document.getElementById('contactName').value = '';
                document.getElementById('contactEmail').value = '';
                document.getElementById('contactCountry').value = '';
                document.getElementById('contactSubject').value = '';
                document.getElementById('contactMessage').value = '';
                openModal();

                if (contactStatus) {
                    contactStatus.innerHTML = '✓ Message sent successfully!';
                    contactStatus.style.color = '#8a9e7b';

                    setTimeout(() => {
                        contactStatus.innerHTML = '';
                    }, 3000);
                }

            } catch (error) {
                console.error('Form submission error:', error);

                if (contactStatus) {
                    contactStatus.innerHTML = '❌ Network error. Please try again.';
                    contactStatus.style.color = '#b55b35';
                }
            } finally {
                contactBtn.disabled = false;
                contactBtn.textContent = 'Send Message';
            }
        }

        if (contactBtn) {
            contactBtn.addEventListener('click', submitContactForm);
        }

        const contactInputs = ['contactName', 'contactEmail', 'contactCountry', 'contactSubject', 'contactMessage'];
        contactInputs.forEach(id => {
            const el = document.getElementById(id);
            if (el) {
                el.addEventListener('keypress', function (e) {
                    if (e.key === 'Enter' && e.target.id !== 'contactMessage') {
                        e.preventDefault();
                        if (contactBtn && !contactBtn.disabled) submitContactForm();
                    }
                });
            }
        });
    </script>
