            function makeAllArticlesClickable() {
                const articles = document.querySelectorAll('#articleList .article-item');
                articles.forEach(article => {
                    if (article.hasAttribute('data-clickable')) return;

                    const titleEl = article.querySelector('.article-title');
                    if (!titleEl) return;

                    const title = titleEl.textContent;
                    const matched = artsData.find(a => a.title === title);

                    if (matched) {
                        article.style.cursor = 'pointer';
                        article.addEventListener('click', (e) => {
                            if (e.target.tagName === 'A' || e.target.closest('a')) return;
                            window.open(matched.link, '_blank');
                        });
                        article.setAttribute('data-clickable', 'true');
                    }
                });
            }

            makeAllArticlesClickable();
            const observer = new MutationObserver(makeAllArticlesClickable);
            observer.observe(document.getElementById('articleList'), { childList: true, subtree: true });
            const loadBtn = document.getElementById('loadMoreBtn');
            if (loadBtn) {
                const originalClick = loadBtn.onclick;
                loadBtn.addEventListener('click', () => {
                    setTimeout(makeAllArticlesClickable, 200);
                });
