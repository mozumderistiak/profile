    <script>
        (function () {
            const portraitRow = document.getElementById('certPortraitRow');
            const landscapeRow = document.getElementById('certLandscapeRow');
            if (!portraitRow || !landscapeRow) return;

            const allCertCards = [
                ...Array.from(portraitRow.querySelectorAll('.cert-card')),
                ...Array.from(landscapeRow.querySelectorAll('.cert-card'))
            ];

            const loadMoreWrap = document.getElementById('loadMoreCertWrap');
            const loadMoreBtn = document.getElementById('loadMoreCertBtn');
            if (!allCertCards.length || !loadMoreWrap || !loadMoreBtn) return;

            const INITIAL_VISIBLE = 6;
            let currentVisible = INITIAL_VISIBLE;

            function showCardsUpTo(count) {
                allCertCards.forEach((card, idx) => {
                    if (idx < count) {
                        card.classList.remove('cert-hidden');
                    } else {
                        card.classList.add('cert-hidden');
                    }
                });
            }

            function updateCertVisibility() {
                const isMobile = window.innerWidth <= 768;

                if (isMobile) {
                    currentVisible = INITIAL_VISIBLE;
                    showCardsUpTo(currentVisible);

                    if (allCertCards.length > INITIAL_VISIBLE) {
                        loadMoreWrap.style.display = 'block';
                        loadMoreBtn.disabled = false;
                        loadMoreBtn.textContent = 'Load More Certifications';
                    } else {
                        loadMoreWrap.style.display = 'none';
                    }
                } else {
                    allCertCards.forEach(card => card.classList.remove('cert-hidden'));
                    loadMoreWrap.style.display = 'none';
                    currentVisible = allCertCards.length;
                }
            }

            function loadMoreCertificates() {
                const isMobile = window.innerWidth <= 768;
                if (!isMobile) return;

                const nextVisible = Math.min(currentVisible + 6, allCertCards.length);
                showCardsUpTo(nextVisible);
